        &lt;div class=&#34;tl-dot&#34;&gt;&lt;/div&gt;
        &lt;div class=&#34;tl-body&#34;&gt;
          &lt;div class=&#34;tl-year&#34;&gt;建国后&lt;/div&gt;
          &lt;div class=&#34;tl-text&#34;&gt;院系历经调整，轮机工程专业持续发展壮大，成为行业输送重要力量&lt;/div&gt;
        &lt;/div&gt;
      &lt;/div&gt;
      &lt;div class=&#34;tl-item&#34;&gt;
        &lt;div class=&#34;tl-dot now&#34;&gt;&lt;/div&gt;
        &lt;div class=&#34;tl-body&#34;&gt;
          &lt;div class=&#34;tl-year&#34;&gt;当代&lt;/div&gt;
          &lt;div class=&#34;tl-text&#34;&gt;拥有完整本硕博培养体系，深度对接绿色航运与数字化转型前沿&lt;/div&gt;
        &lt;/div&gt;
      &lt;/div&gt;
    &lt;/div&gt;
  &lt;/div&gt;
  &lt;!-- ━━ 荣誉成就 ━━ --&gt;
  &lt;div class=&#34;nb-card nb-honor&#34;&gt;
    &lt;div class=&#34;nb-eyebrow&#34;&gt;学院荣誉&lt;/div&gt;
    &lt;div class=&#34;nb-heading&#34;&gt;硬核实力&lt;/div&gt;
    &lt;div class=&#34;honor-grid&#34;&gt;
