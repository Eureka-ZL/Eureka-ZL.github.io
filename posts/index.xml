        &lt;/div&gt;
      &lt;/div&gt;
      &lt;div class=&#34;honor-item&#34;&gt;
        &lt;div class=&#34;honor-icon&#34;&gt;⚙️&lt;/div&gt;
        &lt;div class=&#34;honor-text&#34;&gt;
          &lt;div class=&#34;honor-title&#34;&gt;半军事化管理&lt;/div&gt;
          &lt;div class=&#34;honor-desc&#34;&gt;严谨作风传统，培养精工细作、令行禁止的工程师素质&lt;/div&gt;
        &lt;/div&gt;
      &lt;/div&gt;
      &lt;div class=&#34;honor-item&#34;&gt;
        &lt;div class=&#34;honor-icon&#34;&gt;🌊&lt;/div&gt;
        &lt;div class=&#34;honor-text&#34;&gt;
          &lt;div class=&#34;honor-title&#34;&gt;行业认可度&lt;/div&gt;
          &lt;div class=&#34;honor-desc&#34;&gt;毕业生广布远洋船队，是中国远洋航运的中流砥柱&lt;/div&gt;
        &lt;/div&gt;
      &lt;/div&gt;
      &lt;div class=&#34;honor-item&#34;&gt;
        &lt;div class=&#34;honor-icon&#34;&gt;🔬&lt;/div&gt;
        &lt;div class=&#34;honor-text&#34;&gt;
          &lt;div class=&#34;honor-title&#34;&gt;科研协同&lt;/div&gt;
          &lt;div class=&#34;honor-desc&#34;&gt;深度对接航运数字化转型与绿色海洋工程前沿领域&lt;/div&gt;
        &lt;/div&gt;
      &lt;/div&gt;
    &lt;/div&gt;
  &lt;/div&gt;
  &lt;!-- ━━ 标签云 ━━ --&gt;
  &lt;div class=&#34;nb-card nb-tags&#34;&gt;
    &lt;div class=&#34;nb-eyebrow&#34;&gt;关键词&lt;/div&gt;
